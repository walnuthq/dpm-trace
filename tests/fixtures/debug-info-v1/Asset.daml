module Asset where

import Daml.Script

-- A minimal asset contract used by the dpm-trace debug fixtures.
-- The spans in asset.debug-info.json reference line numbers in this
-- file; keep them in sync when editing.

template Asset
  with
    issuer : Party
    owner : Party
    label : Text
  where
    signatory issuer
    observer owner

    choice Transfer : ContractId Asset
      with
        newOwner : Party
      controller owner
      do
        create this with owner = newOwner

test_transfer : Script ()
test_transfer = do
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  asset <- submit alice do
    createCmd Asset with issuer = alice, owner = alice, label = "Gem"
  debug "transferring asset"
  transferred <- submit alice do
    exerciseCmd asset Transfer with newOwner = bob
  pure ()
